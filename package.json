{
  "name": "tg-bot",
  "description": "Telegram-бота для доступа к Minecraft-серверу",
  "version": "0.3.0",
  "author": "AlexRahvalov <t.me/AlexRahvalov>",
  "contributors": [
    "Claude AI (Anthropic)"
  ],
  "repository": {
    "type": "git",
